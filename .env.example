# =============================================================================
# bpn-ops environment variables
# Copy to .env.local for local development — never commit .env files.
# =============================================================================

# -- Supabase (injected automatically into Edge Functions at runtime) ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -- Anthropic (set via: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
